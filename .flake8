# flake8 configuration.
#
# max-line-length is 88 to match black exactly so the two tools never
# disagree. E203 (whitespace before ':') and W503 (line break before binary
# operator) are disabled per black's documented guidance.
#
# E501 (line too long) is delegated to black: black is the CI-enforced
# formatter and owns the 88-col limit, so the only lines that survive it are
# ones it cannot split (long string/URL literals, alignment tables). flake8
# re-flagging those is noise, so we focus flake8 on logical defects (F-codes,
# E4xx/E7xx) instead of duplicating black's line-length check. (The remaining
# per-file E501 entries below are now redundant no-ops, kept until next touch.)
#
# Pattern note: per-file-ignores keys use a leading `*` so they match
# regardless of the OS path separator -- flake8 fnmatch-compares against the
# reported path, which uses backslashes on Windows.
[flake8]
max-line-length = 88
extend-ignore = E203, W503, E501
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .venv-freshtest,
    captures,
    spikes,
    sw_types.py

# Baselined pre-existing findings in modules that predate the flake8 gate
# (enhancement plan P2.1): E501 in legacy docstrings/comments that black does
# not wrap, plus minor dead code. New code must be clean -- ratchet these
# down whenever one of these files is next touched.
per-file-ignores =
    *codegen.py:E501
    *observe.py:E501
    *locals_io.py:E501,F841
    *mutate.py:E501
    *parameterize.py:E741
    *schema.py:E501
    *validator.py:F401
    *chm_extract.py:E501
    *gen_api_markdown.py:E501
    *gen_sw_types.py:E501
    *test_cli_build_dry_run.py:F401
    *test_doc_coverage.py:F401,E501
    *test_lint.py:F401
    *test_pre_commit_hook.py:F401
    *test_schema.py:F401
    *test_validator.py:F401
    # v0.11 new files: long lines in docstrings/format strings and sys.path
    # hack imports for tools/ tests. Same legacy-baseline pattern as above --
    # ratchet down when next touched.
    *flags.py:E501
    *connection.py:E501
    *store.py:E501
    *check_upstream_drift.py:E501
    *doc_coverage_gate.py:E501
    *regression_check.py:E501
    *test_license_lint.py:E402,E501
    *test_regression_check.py:E402
    *test_upstream_drift.py:E402,E501
    # v0.12 new files: deliberate alignment tables (hints.py iface-feature map)
    # and a few one-off long lines that don't reflow cleanly.
    *hints.py:E501
    *test_manifest.py:E501
    *test_resolver.py:E501
    *test_gc.py:E501
    *test_wrapper.py:E501
