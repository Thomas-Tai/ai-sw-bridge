# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
.venv-*/
venv/
env/
ENV/

# IDE
.vscode/
.idea/
.qoder/
*.swp

# OS
.DS_Store
Thumbs.db
nul

# Runtime data (per-user, auto-created)
captures/
proposals/
.telemetry/

# Build metrics sidecars (written next to a saved .sldprt; observability P3.1)
*.build_metrics.json

# Examples: user-recorded macros that aren't part of the example
examples/**/recorded.swp
examples/**/*_parameterized.bas

# But DO ship the example spec.json and any docs
!examples/**/spec.json
!examples/**/README.md

# Decompiled SW API CHM (reproducible from chm files in the OneDrive tree)
spikes/phase0/_chm_decompiled/
spikes/phase0/_chm_decompiled_swconst/
spikes/phase0/_chm_decompiled_progguide/
spikes/phase0/_chm_decompiled_apiprogguide/

# Temp files from debug sessions
spikes/phase0/_tmp_*.json
docs/_test*.json

# Smoke-test scratch outputs (feature_tree_diff captures, etc.)
tools/snapshots-e2e/


docs/central_idea/