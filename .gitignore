# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
.venv-*/
venv/
env/
ENV/

# IDE
.vscode/
.idea/
.qoder/
.claude/
*.swp

# OS
.DS_Store
Thumbs.db
nul

# Runtime data (per-user, auto-created)
captures/
proposals/
.telemetry/
# L4 checkpoint store — per privacy_review.md §4.1, the .sqlite files
# contain full *_locals.txt snapshots at each feature commit and must
# never enter version control. Users who want some sub-set committed
# (e.g. an audited reproducible build) can negate per-line in their
# own project .gitignore.
.checkpoints/

# Build metrics sidecars (written next to a saved .sldprt; observability P3.1)
*.build_metrics.json

# Examples: user-recorded macros that aren't part of the example
examples/**/recorded.swp
examples/**/*_parameterized.bas

# But DO ship the example spec.json and any docs
!examples/**/spec.json
!examples/**/README.md

# Decompiled SW API CHM (reproducible from chm files in the OneDrive tree)
spikes/phase0/_chm_decompiled/
spikes/phase0/_chm_decompiled_swconst/
spikes/phase0/_chm_decompiled_progguide/
spikes/phase0/_chm_decompiled_apiprogguide/

# Temp files from debug sessions
spikes/phase0/_tmp_*.json
docs/_test*.json

# Smoke-test scratch outputs (feature_tree_diff captures, etc.)
tools/snapshots-e2e/


docs/central_idea/
docs/central_idea_vs_implementation_audit.md
docs/regression_checks/

# Upstream reference repo clones — see docs/reference_repos.md
# (re-fetchable via tools/clone_references.sh; never commit the clones
# themselves, they bloat the repo and are public elsewhere).
references/

# PR body + release-note drafts (one-shot artifacts; not part of the repo)
.github/pr_body_*.md
.github/release_notes_*.md

# Route-C in-process add-in build outputs — NEVER track compiled binaries.
# The proprietary SOLIDWORKS-interop-linked RouteCAddin.dll was excised from
# full history via git-filter-repo (W68 IP scrub, 2026-06-20). Source (.cs/.ps1)
# is kept; build artifacts are reproducible and must not re-enter the tree.
spikes/v0_2x/route_c/*.dll
spikes/v0_2x/route_c/bin/
spikes/v0_2x/route_c/obj/

# Generated SOLIDWORKS API references — regenerable build outputs, not sources.
# Committed sources: tools/_api_extract_input.json (curated input) + the
# generators/guard (tools/gen_api_markdown.py, tools/export_full_sw_api.ps1,
# tools/verify_api_reference_against_dll.ps1). Regenerate the outputs locally
# (needs a SW install + decompiled CHM):
#   api_reference.*  : chm_extract.py batch _api_extract_input.json + gen_api_markdown.py
#   sw_api_full.*    : export_full_sw_api.ps1   (3MB+; all redist assemblies)
docs/api_reference.json
docs/api_reference.md
docs/sw_api_full.json
docs/sw_api_full.md
docs/ribbon_api_progress_relation_audit.md
